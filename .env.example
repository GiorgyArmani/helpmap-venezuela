# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored — never commit real credentials.

# --- Supabase (required) ---------------------------------------------------
# Project Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to the client. Used by admin routes.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket names (defaults shown are used if unset)
NEXT_PUBLIC_SUPABASE_INTAKE_BUCKET=intake-photos
NEXT_PUBLIC_SUPABASE_CONTRIB_BUCKET=contrib-photos

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=

# --- SMTP / email (contact form, volunteer notifications) -------------------
SMTP_HOST=mail.helpmapvzla.net
SMTP_PORT=465
SMTP_USER=info@helpmapvzla.net
SMTP_PASS=
SMTP_FROM=
CONTACT_TO=

# --- n8n webhooks (centers/lists/intake sync) --------------------------------
N8N_CENTERS_WEBHOOK_URL=
N8N_UPLOAD_WEBHOOK_URL=
N8N_LISTS_WEBHOOK_URL=

# --- Acopiove integration -----------------------------------------------------
ACOPIOVE_API_URL=https://api.acopiove.org/v1
ACOPIOVE_PUSH_ENABLED=0

# --- Cron / scheduled routes (app/api/refugios/sync) -------------------------
# Shared secret expected on the Authorization header of the Vercel cron request.
CRON_SECRET=

# --- Rate limiting / reverse proxy --------------------------------------------
# Set to "true" only if the app sits behind Cloudflare and CF-Connecting-IP is trusted.
TRUST_CF_IP=false
TRUSTED_PROXY_HOPS=1
